REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://incident-agent@localhost:5432/incident-agent

DEMO_HOSTING_TARGET=render
DEMO_ENVIRONMENT=demo
DEMO_BASE_URL=http://localhost:8002
GATEWAY_BASE_URL=http://localhost:8000

REQUIRE_APPROVAL=true
USE_DEMO_STATIC_TRIAGE=true

DATADOG_WEBHOOK_TOKEN=replace-me
DEMO_TRIGGER_TOKEN=replace-me
APPROVAL_SIGNING_SECRET=replace-me

# Slack bot OAuth token from the Slack app (set in deployment only; do not commit real tokens)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=C0123456789

# Optional: protects POST /api/admin/incidents/flush on the interface service
DEMO_ADMIN_FLUSH_TOKEN=

SIMULATOR_GATEWAY_URL=http://localhost:8000
SIMULATOR_SERVICE=checkout-demo
SIMULATOR_ENV=demo
SIMULATOR_THRESHOLD_MS=800
SIMULATOR_INTERVAL_SECONDS=15
SIMULATOR_PATTERN=220,260,310,420,760,980,1200,700,430,310
